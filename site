  --color-bg:        #08090c;
  --color-surface:   #0e1016;
  --color-surface-2: #14161e;
  --color-surface-3: #1a1d28;
  --color-border:    #242736;
  --color-border-subtle: #181b28;

  --color-text:       #e0dfe6;
  --color-text-muted: #8589a0;
  --color-text-faint: #4a4e65;

  /* Steel blue from logo glow */
  --color-accent:       #4da8e8;
  --color-accent-hover: #6dc0f8;
  --color-accent-dim:   #2a7ab8;
  --color-accent-faint: rgba(77, 168, 232, 0.10);
  --color-accent-glow:  rgba(77, 168, 232, 0.25);

  /* Chrome silver highlight */
  --color-chrome:       #c0c8d8;
  --color-chrome-dim:   #8890a0;

  --shadow-sm: 0 1px 2px rgba(0,0,0,0.4);
  --shadow-md: 0 4px 16px rgba(0,0,0,0.5);
  --shadow-lg: 0 12px 40px rgba(0,0,0,0.6);
}

/* --- LIGHT MODE --- */
[data-theme="light"] {
  --color-bg:        #f3f4f8;
  --color-surface:   #ffffff;
  --color-surface-2: #eceef4;
  --color-surface-3: #e2e5ee;
  --color-border:    #c8ccd8;
  --color-border-subtle: #d8dce6;

  --color-text:       #141624;
  --color-text-muted: #5a5e74;
  --color-text-faint: #9498ae;

  --color-accent:       #2074b8;
  --color-accent-hover: #185a94;
  --color-accent-dim:   #3090d4;
  --color-accent-faint: rgba(32, 116, 184, 0.07);
  --color-accent-glow:  rgba(32, 116, 184, 0.15);

  --color-chrome:       #3a3e50;
  --color-chrome-dim:   #6a6e80;

  --shadow-sm: 0 1px 2px rgba(0,0,0,0.06);
  --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
  --shadow-lg: 0 12px 40px rgba(0,0,0,0.12);
}

/* System preference fallback */
@media (prefers-color-scheme: light) {
  :root:not([data-theme]) {
    --color-bg:        #f3f4f8;
    --color-surface:   #ffffff;
    --color-surface-2: #eceef4;
    --color-surface-3: #e2e5ee;
    --color-border:    #c8ccd8;
    --color-border-subtle: #d8dce6;
    --color-text:       #141624;
    --color-text-muted: #5a5e74;
    --color-text-faint: #9498ae;
    --color-accent:       #2074b8;
    --color-accent-hover: #185a94;
    --color-accent-dim:   #3090d4;
    --color-accent-faint: rgba(32, 116, 184, 0.07);
    --color-accent-glow:  rgba(32, 116, 184, 0.15);
    --color-chrome:       #3a3e50;
    --color-chrome-dim:   #6a6e80;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.06);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
    --shadow-lg: 0 12px 40px rgba(0,0,0,0.12);
  }
}


/* ========================================================
   GLOBAL
   ======================================================== */
body {
  font-family: var(--font-body);
  overflow-x: hidden;
}

.container {
  max-width: var(--content-wide);
  margin-inline: auto;
  padding-inline: var(--space-6);
}

a {
  color: var(--color-accent);
  text-decoration: none;
}
a:hover {
  color: var(--color-accent-hover);
}

strong {
  color: var(--color-accent);
  font-weight: 600;
}


/* ========================================================
   NAV
   ======================================================== */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  background: rgba(8, 9, 12, 0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--color-border-subtle);
  transition: background var(--transition-interactive),
              border-color var(--transition-interactive);
}

[data-theme="light"] .nav {
  background: rgba(243, 244, 248, 0.88);
}

.nav__inner {
  max-width: var(--content-wide);
  margin-inline: auto;
  padding: var(--space-3) var(--space-6);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-6);
}

.nav__logo {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-family: var(--font-display);
  font-weight: 600;
  font-size: var(--text-sm);
  color: var(--color-text);
  letter-spacing: 0.03em;
  text-transform: uppercase;
}
.nav__logo:hover {
  color: var(--color-accent);
}

.nav__logo-img {
  width: 36px;
  height: 36px;
  border-radius: var(--radius-md);
  object-fit: cover;
}

.nav__links {
  display: flex;
  gap: var(--space-6);
}
.nav__links a {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-text-muted);
  letter-spacing: 0.01em;
  transition: color var(--transition-interactive);
  position: relative;
}
.nav__links a:hover {
  color: var(--color-text);
}
.nav__links a::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0; right: 0;
  height: 1px;
  background: var(--color-accent);
  transform: scaleX(0);
  transition: transform var(--transition-interactive);
}
.nav__links a:hover::after {
  transform: scaleX(1);
}

.nav__actions {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.nav__toggle,
.nav__hamburger {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-md);
  color: var(--color-text-muted);
  transition: color var(--transition-interactive),
              background var(--transition-interactive);
}
.nav__toggle:hover,
.nav__hamburger:hover {
  color: var(--color-text);
  background: var(--color-accent-faint);
}

.nav__hamburger {
  display: none;
}

.nav__mobile {
  display: none;
  flex-direction: column;
  gap: var(--space-2);
  padding: var(--space-4) var(--space-6) var(--space-6);
  border-top: 1px solid var(--color-border-subtle);
}
.nav__mobile.is-open {
  display: flex;
}
.nav__mobile a {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-text-muted);
  padding: var(--space-2) 0;
}
.nav__mobile a:hover {
  color: var(--color-text);
}

@media (max-width: 768px) {
  .nav__links { display: none; }
  .nav__hamburger { display: flex; }
}


/* ========================================================
   HERO
   ======================================================== */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-24) var(--space-6) var(--space-16);
  overflow: hidden;
}

.hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero__bg canvas {
  width: 100%;
  height: 100%;
}

.hero__content {
  position: relative;
  z-index: 1;
  text-align: center;
  max-width: 820px;
}

.hero__logo-mark {
  margin-bottom: var(--space-8);
  display: flex;
  justify-content: center;
}
.hero__logo-img {
  width: 120px;
  height: 120px;
  border-radius: var(--radius-xl);
  object-fit: cover;
  box-shadow: 0 0 60px var(--color-accent-glow),
              0 0 120px rgba(77, 168, 232, 0.08);
}

[data-theme="light"] .hero__logo-img {
  box-shadow: 0 4px 24px rgba(0,0,0,0.1);
}

.hero__eyebrow {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: var(--color-accent);
  margin-bottom: var(--space-6);
}

.hero__title {
  font-family: var(--font-display);
  font-size: var(--text-hero);
  font-weight: 700;
  line-height: 0.92;
  letter-spacing: -0.03em;
  color: var(--color-chrome);
  margin-bottom: var(--space-8);
}
.hero__accent {
  color: var(--color-accent);
  text-shadow: 0 0 40px var(--color-accent-glow);
}

[data-theme="light"] .hero__accent {
  text-shadow: none;
}

.hero__subtitle {
  font-size: var(--text-base);
  color: var(--color-text-muted);
  max-width: 560px;
  margin-inline: auto;
  margin-bottom: var(--space-10);
  line-height: 1.75;
}

.hero__cta {
  display: flex;
  gap: var(--space-4);
  justify-content: center;
  flex-wrap: wrap;
}

.hero__scroll {
  position: absolute;
  bottom: var(--space-8);
  left: 50%;
  transform: translateX(-50%);
  color: var(--color-text-faint);
  animation: float 2.5s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}


/* ========================================================
   BUTTONS
   ======================================================== */
.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-8);
  border-radius: var(--radius-full);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 600;
  letter-spacing: 0.02em;
  cursor: pointer;
  transition: all var(--transition-interactive);
}

.btn--primary {
  background: var(--color-accent);
  color: #ffffff;
}
.btn--primary:hover {
  background: var(--color-accent-hover);
  color: #ffffff;
  transform: translateY(-1px);
  box-shadow: 0 4px 24px var(--color-accent-glow);
}

.btn--ghost {
  background: transparent;
  color: var(--color-text-muted);
  border: 1px solid var(--color-border);
}
.btn--ghost:hover {
  color: var(--color-text);
  border-color: var(--color-text-muted);
}


/* ========================================================
   SECTIONS
   ======================================================== */
.section {
  padding: clamp(var(--space-16), 8vw, var(--space-32)) 0;
}
.section--alt {
  background: var(--color-surface);
}

.section__eyebrow {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: var(--color-accent);
  margin-bottom: var(--space-4);
}

.section__title {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: -0.02em;
  margin-bottom: var(--space-6);
}

.section__intro {
  font-size: var(--text-base);
  color: var(--color-text-muted);
  max-width: 600px;
  margin-bottom: var(--space-12);
  line-height: 1.75;
}


/* ========================================================
   ABOUT — Asymmetric Grid
   ======================================================== */
.section-grid {
  display: grid;
  gap: var(--space-12);
}
.section-grid--asymmetric {
  grid-template-columns: 1fr;
}
@media (min-width: 768px) {
  .section-grid--asymmetric {
    grid-template-columns: 1.4fr 1fr;
    align-items: start;
  }
}

.section-grid__text p {
  color: var(--color-text-muted);
  margin-bottom: var(--space-5);
  line-height: 1.8;
}

.section-grid__aside {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.stat-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  transition: border-color var(--transition-interactive),
              box-shadow var(--transition-interactive);
}

[data-theme="light"] .stat-card {
  background: var(--color-surface-2);
}

.stat-card:hover {
  border-color: var(--color-accent-dim);
  box-shadow: 0 0 20px var(--color-accent-faint);
}

.stat-card__icon {
  color: var(--color-accent);
  margin-bottom: var(--space-4);
}

.stat-card__label {
  font-size: var(--text-xs);
  color: var(--color-text-faint);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: var(--space-1);
}

.stat-card__value {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-2);
}

.stat-card__desc {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: 1.6;
}


/* ========================================================
   ABILITIES GRID
   ======================================================== */
.abilities-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(320px, 100%), 1fr));
  gap: var(--space-6);
}

.ability-card {
  background: var(--color-surface-2);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-lg);
  padding: var(--space-8);
  transition: border-color var(--transition-interactive),
              transform var(--transition-interactive),
              box-shadow var(--transition-interactive);
}
.ability-card:hover {
  border-color: var(--color-accent-dim);
  transform: translateY(-2px);
  box-shadow: 0 0 24px var(--color-accent-faint),
              var(--shadow-md);
}

.ability-card__icon {
  color: var(--color-accent);
  margin-bottom: var(--space-5);
}

.ability-card__title {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: var(--space-3);
}

.ability-card__desc {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: 1.7;
}


/* ========================================================
   PHILOSOPHY
   ======================================================== */
.philosophy-layout {
  display: grid;
  gap: var(--space-12);
}

.philosophy-content {
  display: grid;
  gap: var(--space-8);
}

.philosophy-content > p {
  color: var(--color-text-muted);
  line-height: 1.8;
  font-size: var(--text-base);
}

.pullquote {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 500;
  color: var(--color-text);
  line-height: 1.4;
  border-left: 3px solid var(--color-accent);
  padding-left: var(--space-6);
  margin: var(--space-4) 0;
  font-style: italic;
}
.pullquote cite {
  display: block;
  font-size: var(--text-sm);
  font-style: normal;
  color: var(--color-text-faint);
  margin-top: var(--space-3);
}

.philosophy-principles {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
  gap: var(--space-6);
  margin-top: var(--space-4);
}

.principle {
  padding: var(--space-6);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-lg);
  background: var(--color-surface);
  transition: border-color var(--transition-interactive),
              box-shadow var(--transition-interactive);
}
.principle:hover {
  border-color: var(--color-accent-dim);
  box-shadow: 0 0 20px var(--color-accent-faint);
}

[data-theme="light"] .principle {
  background: var(--color-surface-2);
}

.principle__number {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--color-accent);
  display: block;
  margin-bottom: var(--space-3);
  letter-spacing: 0.05em;
}

.principle__title {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: var(--space-3);
}

.principle__text {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: 1.7;
}


/* ========================================================
   WORKFLOWS
   ======================================================== */
.workflows-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(300px, 100%), 1fr));
  gap: var(--space-6);
}

.workflow-card {
  background: var(--color-surface-2);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-lg);
  padding: var(--space-8);
  transition: border-color var(--transition-interactive),
              box-shadow var(--transition-interactive);
}
.workflow-card:hover {
  border-color: var(--color-accent-dim);
  box-shadow: 0 0 20px var(--color-accent-faint);
}

.workflow-card__number {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 700;
  color: var(--color-accent);
  opacity: 0.2;
  line-height: 1;
  margin-bottom: var(--space-4);
}

.workflow-card__title {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: var(--space-3);
}

.workflow-card__desc {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: 1.7;
  margin-bottom: var(--space-5);
}

.workflow-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.tag {
  font-size: var(--text-xs);
  font-weight: 500;
  padding: var(--space-1) var(--space-3);
  background: var(--color-accent-faint);
  color: var(--color-accent);
  border-radius: var(--radius-full);
  letter-spacing: 0.02em;
}


/* ========================================================
   LAB / DEMO
   ======================================================== */
.lab-canvas-wrap {
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: var(--radius-xl);
  overflow: hidden;
  border: 1px solid var(--color-border-subtle);
  background: var(--color-surface);
  position: relative;
  cursor: crosshair;
}
.lab-canvas-wrap canvas {
  width: 100%;
  height: 100%;
  display: block;
}


/* ========================================================
   FOOTER
   ======================================================== */
.footer {
  padding: var(--space-16) 0 var(--space-8);
  border-top: 1px solid var(--color-border-subtle);
}

.footer__inner {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-4);
}

.footer__brand {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-family: var(--font-display);
  font-weight: 600;
  font-size: var(--text-sm);
  color: var(--color-text);
  letter-spacing: 0.03em;
  text-transform: uppercase;
}

.footer__logo-img {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
  object-fit: cover;
}

.footer__statement {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  max-width: 480px;
  line-height: 1.7;
}

.footer__contact a {
  font-size: var(--text-sm);
  color: var(--color-accent);
  font-weight: 500;
}
.footer__contact a:hover {
  color: var(--color-accent-hover);
}

.footer__links a {
  font-size: var(--text-xs);
  color: var(--color-text-faint);
}
.footer__links a:hover {
  color: var(--color-accent);
}

.footer__copy {
  font-size: var(--text-xs);
  color: var(--color-text-faint);
}


/* ========================================================
   SCROLL REVEAL (IntersectionObserver-driven)
   ======================================================== */
.reveal {
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
              transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
}
.reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}

@media (prefers-reduced-motion: reduce) {
  .reveal {
    opacity: 1;
    transform: none;
    transition: none;
  }
}

/* ========================================================
   CRAIG CLAW — app.js
